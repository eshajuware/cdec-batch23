apiVersion: v1
clusters:
- cluster:
    certificate-authority-data: 
    server: https://39A440CD8D8602357D9D053D7E7A09AB.yl4.ap-south-1.eks.amazonaws.com
  name: my-cluster.ap-south-1.eksctl.io
contexts:
- context:
    cluster: my-cluster.ap-south-1.eksctl.io
    user: iam-root-account@my-cluster.ap-south-1.eksctl.io
  name: iam-root-account@my-cluster.ap-south-1.eksctl.io
current-context: iam-root-account@my-cluster.ap-south-1.eksctl.io
kind: Config
users:
- name: iam-root-account@my-cluster.ap-south-1.eksctl.io
  user:
    exec:
      apiVersion: client.authentication.k8s.io/v1beta1
      args:
      - eks
      - get-token
      - --output
      - json
      - --cluster-name
      - my-cluster
      - --region
      - ap-south-1
      command: aws
      env:
      - name: AWS_STS_REGIONAL_ENDPOINTS
        value: regional
      provideClusterInfo: false
